# Replace with your Project URL from Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
# Legacy fallback key (prefer service role key below)
SUPABASE_KEY=your-supabase-key
# Must be a real service_role key for admin write actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=optional-local-jwt-secret
LOG_LEVEL=INFO
ENVIRONMENT=development
# For production: replace with your actual domain(s), comma-separated
# Example: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
POST_CREATE_LIMIT_PER_MINUTE=5
VOTE_LIMIT_PER_MINUTE=30
TEAM_JOIN_LIMIT_PER_10MIN=10
ADMIN_USER_IDS=00000000-0000-0000-0000-000000000000,00000000-0000-0000-0000-111111111111
